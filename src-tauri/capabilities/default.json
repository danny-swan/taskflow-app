{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for TaskFlow desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "dialog:default",
    "dialog:allow-open",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "os:default",
    "os:allow-platform",
    "os:allow-version",
    "deep-link:default",
    "deep-link:allow-is-registered",
    "deep-link:allow-register"
  ]
}
