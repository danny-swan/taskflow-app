# Supabase — публичные значения (anon key безопасно вшивать в клиент, защищён RLS).
# С v0.9.35-dev.6.1 значения ОБЯЗАТЕЛЬНЫ (fallback убран) — без них бандл стартует
# с ошибкой. Задавать в .env.local (dev) или в CI secrets (build).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-here

# v0.9.23: Sentry DSN — публичный, безопасно вшивать в клиент.
# В dev без него всё работает; в CI приходит из secrets.SENTRY_DSN (если добавите),
# либо оставьте пустым — Sentry просто не будет инициализирован.
VITE_SENTRY_DSN=

# v0.9.23: Cloudflare Turnstile Site Key — публичный, безопасно вшивать в клиент.
# Test key для локальной разработки/E2E (always passes): 1x00000000000000000000AA
# В CI приходит из secrets.TURNSTILE_SITE_KEY.
VITE_TURNSTILE_SITE_KEY=

# ============================================================================
# v0.9.35-dev.6.1 — Конфиг монетизации
# ============================================================================
# Секретные значения — только в .env.local (в .gitignore) или в CI secrets.
# Пустые — UI грациозно скрывает соответствующие блоки/цены.

# Admin-email override — comma-separated. Пусто → admin-режима нет.
# Для тестов vitest автоматически подставляется admin@example.test.
VITE_ADMIN_EMAILS=

# Альтернативные способы оплаты (все опциональные).
# Каждое пустое значение → блок не показывается. Все пустые → accordion целиком скрыт.
VITE_PAY_CLOUDTIPS_URL=
VITE_PAY_TON=
VITE_PAY_USDT_TRC20=
VITE_PAY_USDT_ERC20=

# Цены (как строки в UI — включая валюту). Пустое → "цена скоро".
# Пример: VITE_PAY_PRICE_MONTHLY="299 ₽"
VITE_PAY_PRICE_MONTHLY=
VITE_PAY_PRICE_ANNUAL=
VITE_PAY_PRICE_LIFETIME=
